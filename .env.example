# ============================================================================
# Avicenna Platform — environment variables
# Copy this file to .env and adjust for your environment.
# ============================================================================

# ---- Django / backend ----
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_TIME_ZONE=Asia/Tashkent

# ---- Database (leave POSTGRES_DB empty to use sqlite locally) ----
POSTGRES_DB=
POSTGRES_USER=avicenna
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---- CORS (frontend origins, comma-separated) ----
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- AI service (Django → AI) ----
AI_SERVICE_URL=http://127.0.0.1:8001

# ---- OpenAI (used by the AI service) ----
# Leave blank in dev to fall back to the deterministic rule-based answers.
# Set in Railway env on the ai-service service to enable GPT-3.5 responses.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# ---- Frontend (Next.js → backend / AI) ----
BACKEND_INTERNAL_URL=http://127.0.0.1:8000
AI_INTERNAL_URL=http://127.0.0.1:8001

# ---- Demo seed (safe to leave default in dev; override in prod) ----
DEMO_ADMIN_PASSWORD=admin1234
DEMO_USER_PASSWORD=demo1234
