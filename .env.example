# ============================================================================
# Avicenna Platform — environment variables
# Copy this file to .env and adjust for your environment.
# ============================================================================

# ---- Django / backend ----
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_TIME_ZONE=Asia/Tashkent

# ---- Database (leave POSTGRES_DB empty to use sqlite locally) ----
POSTGRES_DB=
POSTGRES_USER=avicenna
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---- CORS (frontend origins, comma-separated) ----
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- AI service (Django → AI) ----
AI_SERVICE_URL=http://127.0.0.1:8001

# ---- LLM provider (used by the AI service) ----
# The AI service uses the OpenAI Python SDK, which is compatible with
# OpenAI itself, Groq, Google Gemini's compat endpoint, OpenRouter, etc.
# Leave OPENAI_API_KEY blank in dev to fall back to the rule-based answers.
# NEVER put a real key in this file — it is committed to git.
# Real keys belong in .env (which is gitignored) or in Railway env vars.
#
# OpenAI:    OPENAI_BASE_URL empty, OPENAI_MODEL=gpt-3.5-turbo (paid)
# Groq:      OPENAI_BASE_URL=https://api.groq.com/openai/v1, OPENAI_MODEL=llama-3.1-8b-instant (free)
# Gemini:    OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/, OPENAI_MODEL=gemini-1.5-flash (free tier)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_BASE_URL=

# ---- Frontend (Next.js → backend / AI) ----
BACKEND_INTERNAL_URL=http://127.0.0.1:8000
AI_INTERNAL_URL=http://127.0.0.1:8001

# ---- Demo seed (safe to leave default in dev; override in prod) ----
DEMO_ADMIN_PASSWORD=admin1234
DEMO_USER_PASSWORD=demo1234
